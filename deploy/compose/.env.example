# Sao chép thành .env (không commit). Chú thích tiếng Việt.

# Postgres
DB_NAME=giapha
DB_USER=giapha
DB_PASSWORD=giapha
DB_URL=jdbc:postgresql://localhost:5432/giapha

# Redis
REDIS_URL=redis://localhost:6379

# Elasticsearch — để trống = dùng PG FTS
ES_URL=

# MinIO
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=giapha

# Keycloak
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
KC_ISSUER_URI=http://localhost:8081/realms/jhipster

# App
APP_BASE_URL=http://localhost:3000
APP_API_PUBLIC_URL=http://localhost:8080
KC_PUBLIC_ISSUER_URI=http://localhost:8081/realms/jhipster
DEFAULT_TREE_SLUG=ho-hoang
SERVER_PORT=8080
PORTAL_PORT=3000
ADMIN_PORT=5173
SPRING_PROFILES_ACTIVE=prod
JASYPT_ENCRYPTOR_PASSWORD=change-me-in-staging
# Images (GHCR) — để trống thì compose build local
# API_IMAGE=ghcr.io/caprocute/giaphadongho/api:main
# PORTAL_IMAGE=ghcr.io/caprocute/giaphadongho/portal:main
# ADMIN_IMAGE=ghcr.io/caprocute/giaphadongho/admin:main

# imgproxy (tuỳ chọn)
IMGPROXY_KEY=
IMGPROXY_SALT=

# Thông báo (R2)
SMTP_HOST=
ZALO_OA_ACCESS_TOKEN=
