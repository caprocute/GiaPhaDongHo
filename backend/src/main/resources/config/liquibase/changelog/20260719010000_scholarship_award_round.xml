<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- SRS-12c / F8 — đợt trao + suất học bổng -->
    <changeSet id="20260719010000-1" author="giapha">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="scholarship_award_round"/>
            </not>
        </preConditions>
        <createTable tableName="scholarship_award_round">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="varchar(64)"/>
            <column name="open_from" type="${datetimeType}"/>
            <column name="open_to" type="${datetimeType}"/>
            <column name="default_amount" type="decimal(21,2)"/>
            <column name="status" type="varchar(32)"/>
            <column name="note" type="varchar(1024)"/>
            <column name="created_at" type="${datetimeType}"/>
            <column name="closed_at" type="${datetimeType}"/>
            <column name="created_by" type="varchar(255)"/>
            <column name="closed_by" type="varchar(255)"/>
            <column name="tree_id" type="bigint"/>
            <column name="fund_campaign_id" type="bigint"/>
            <column name="honor_event_id" type="bigint"/>
        </createTable>
    </changeSet>

    <changeSet id="20260719010000-2" author="giapha">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="scholarship_award_round"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_sch_award_round__tree"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="scholarship_award_round" baseColumnNames="tree_id"
            constraintName="fk_sch_award_round__tree"
            referencedTableName="family_tree" referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="scholarship_award_round" baseColumnNames="fund_campaign_id"
            constraintName="fk_sch_award_round__fund"
            referencedTableName="donation_campaign" referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="scholarship_award_round" baseColumnNames="honor_event_id"
            constraintName="fk_sch_award_round__event"
            referencedTableName="clan_event" referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="20260719010000-3" author="giapha">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="scholarship_award"/>
            </not>
        </preConditions>
        <createTable tableName="scholarship_award">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="amount" type="decimal(21,2)">
                <constraints nullable="false"/>
            </column>
            <column name="awarded_at" type="${datetimeType}"/>
            <column name="awarded_by" type="varchar(255)"/>
            <column name="note" type="varchar(1024)"/>
            <column name="round_id" type="bigint"/>
            <column name="entry_id" type="bigint"/>
        </createTable>
        <addUniqueConstraint
            tableName="scholarship_award"
            columnNames="round_id, entry_id"
            constraintName="ux_sch_award__round_entry"/>
    </changeSet>

    <changeSet id="20260719010000-4" author="giapha">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="scholarship_award"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_sch_award__round"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="scholarship_award" baseColumnNames="round_id"
            constraintName="fk_sch_award__round"
            referencedTableName="scholarship_award_round" referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="scholarship_award" baseColumnNames="entry_id"
            constraintName="fk_sch_award__entry"
            referencedTableName="scholarship_entry" referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>
