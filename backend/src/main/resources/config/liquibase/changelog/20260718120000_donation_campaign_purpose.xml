<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- F4/F8 — mục đích quỹ công đức (general | scholarship) -->
    <changeSet id="20260718120000-1" author="giapha">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="donation_campaign" columnName="purpose"/>
            </not>
        </preConditions>
        <addColumn tableName="donation_campaign">
            <column name="purpose" type="varchar(64)" defaultValue="general">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="20260718120000-2" author="giapha">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="donation_campaign" columnName="purpose"/>
        </preConditions>
        <update tableName="donation_campaign">
            <column name="purpose" value="general"/>
            <where>purpose IS NULL OR purpose = ''</where>
        </update>
    </changeSet>
</databaseChangeLog>
