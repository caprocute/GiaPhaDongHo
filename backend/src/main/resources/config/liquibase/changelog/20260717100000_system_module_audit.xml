<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260717100000-1" author="giapha">
        <createTable tableName="module_registry">
            <column name="code" type="varchar(64)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="enabled" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="config_json" type="${clobType}"/>
        </createTable>
    </changeSet>

    <changeSet id="20260717100000-2" author="giapha">
        <createTable tableName="audit_log">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="actor" type="varchar(128)"/>
            <column name="action" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="varchar(64)"/>
            <column name="entity_id" type="varchar(64)"/>
            <column name="detail_json" type="${clobType}"/>
            <column name="created_at" type="${datetimeType}"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
