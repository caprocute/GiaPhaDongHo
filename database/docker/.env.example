# Copy sang .env rồi sửa mật khẩu:  cp .env.example .env
# docker compose tự đọc file .env cùng thư mục.

POSTGRES_DB=giapha
POSTGRES_USER=giapha
POSTGRES_PASSWORD=changeme-strong-db

# Cổng map ra host. Mặc định 15432 để khớp application-dev.yml của app.
# Nếu tunnel DEV (:15432) đang chạy, đổi sang cổng khác (vd 15433) để tránh trùng.
POSTGRES_PORT=15432
