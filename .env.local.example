# App local trỏ vào tunnel (sau khi: deploy/scripts/tunnel-infra.sh start)

DB_URL=jdbc:postgresql://localhost:15432/giapha
DB_USER=giapha
DB_PASSWORD=changeme-strong-db

REDIS_URL=redis://:changeme-strong-redis@localhost:16379

MINIO_ENDPOINT=http://localhost:19000
MINIO_ACCESS_KEY=giapha
MINIO_SECRET_KEY=changeme-strong-minio
MINIO_BUCKET=giapha

ES_URL=http://localhost:19200

KC_ISSUER_URI=http://localhost:18086/realms/jhipster

# Quản trị tài khoản (FR-12.16) — Admin API máy chủ đăng nhập (tunnel :18086)
# Mật khẩu phải khớp bootstrap admin trên server DEV (GPH_KC_ADMIN_PASSWORD), không phải mặc định "admin".
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=<lấy từ container Keycloak / deploy/remote/.env>
# KC_SERVER_URL=http://localhost:18086

# FE OIDC — copy thêm:
#   frontend/apps/admin/.env.example  → frontend/apps/admin/.env.local
#   frontend/apps/portal/.env.example → frontend/apps/portal/.env.local
# Giá trị mặc định (tunnel Keycloak :18086):
#   VITE_OIDC_AUTHORITY=http://localhost:18086/realms/jhipster
#   VITE_OIDC_CLIENT_ID=giapha_admin
#   NEXT_PUBLIC_OIDC_AUTHORITY=http://localhost:18086/realms/jhipster
#   NEXT_PUBLIC_OIDC_CLIENT_ID=giapha_portal

# Jasypt master password (runtime) — không commit giá trị thật
JASYPT_ENCRYPTOR_PASSWORD=
